---
/**
 * App-store download buttons. Drawn as inline SVG so no external requests
 * are needed (keeps the Content-Security-Policy strict).
 */
export const APP_STORE_URL = 'https://apps.apple.com/us/app/practicing-presence/id1467007716';
export const PLAY_STORE_URL = 'https://play.google.com/store/apps/details?id=com.zeek.practicingpresence';
---

<div class="badges">
  <a href={APP_STORE_URL} rel="noopener" aria-label="Download Practicing Presence on the App Store">
    <svg viewBox="0 0 180 53" width="180" height="53" role="img" aria-hidden="true">
      <rect x="1" y="1" width="178" height="51" rx="10" fill="#000" stroke="#a6a6a6" stroke-width="1"></rect>
      <path
        fill="#fff"
        d="M36.4 27.1c0-3.5 2.9-5.2 3-5.3-1.6-2.4-4.2-2.7-5.1-2.7-2.1-.2-4.2 1.3-5.3 1.3-1.1 0-2.8-1.3-4.6-1.2-2.3 0-4.5 1.4-5.7 3.5-2.5 4.3-.6 10.6 1.7 14 1.2 1.7 2.6 3.6 4.4 3.5 1.8-.1 2.4-1.1 4.6-1.1 2.1 0 2.7 1.1 4.6 1.1 1.9 0 3.1-1.7 4.3-3.4 1.4-2 1.9-3.9 2-4-.1-.1-3.8-1.5-3.9-5.7zM33 16.9c1-1.2 1.6-2.8 1.5-4.4-1.4.1-3.1.9-4.1 2.1-.9 1-1.7 2.7-1.5 4.3 1.5.1 3.1-.8 4.1-2z"
      ></path>
      <text x="56" y="22" fill="#fff" font-family="Helvetica, Arial, sans-serif" font-size="9.5">Download on the</text>
      <text x="56" y="40" fill="#fff" font-family="Helvetica, Arial, sans-serif" font-size="17" font-weight="bold">App Store</text>
    </svg>
  </a>
  <a href={PLAY_STORE_URL} rel="noopener" aria-label="Get Practicing Presence on Google Play">
    <svg viewBox="0 0 180 53" width="180" height="53" role="img" aria-hidden="true">
      <rect x="1" y="1" width="178" height="51" rx="10" fill="#000" stroke="#a6a6a6" stroke-width="1"></rect>
      <g transform="translate(15,12)">
        <path d="M0 1.5v26l13.5-13z" fill="#00d7fe"></path>
        <path d="M0 1.5 13.5 14.5 18 10 3 .6C1.8-.1.6.2 0 1.5z" fill="#00f076"></path>
        <path d="M0 27.5c.6 1.3 1.8 1.6 3 1l15-9.5-4.5-4.5z" fill="#f4364c"></path>
        <path d="m18 10-4.5 4.5L18 19l6-3.8c1.4-.9 1.4-2.5 0-3.4z" fill="#ffce00"></path>
      </g>
      <text x="56" y="22" fill="#fff" font-family="Helvetica, Arial, sans-serif" font-size="9.5">GET IT ON</text>
      <text x="56" y="40" fill="#fff" font-family="Helvetica, Arial, sans-serif" font-size="17" font-weight="bold">Google Play</text>
    </svg>
  </a>
</div>

<style>
  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    align-items: center;
  }

  .badges a {
    display: inline-block;
    line-height: 0;
    border-radius: 10px;
    transition: transform 120ms ease;
  }

  .badges a:hover {
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .badges a,
    .badges a:hover {
      transition: none;
      transform: none;
    }
  }
</style>
