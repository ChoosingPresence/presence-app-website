---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/tutorials/', label: 'Tutorials' },
  { href: '/about/', label: 'About' },
];
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/">
      <img src="/images/app-icon.png" alt="" width="44" height="44" />
      <span class="brand__text">
        <strong>Practicing Presence</strong>
        <small>A Christian Way</small>
      </span>
    </a>

    <div class="header-actions">
      <button
        id="theme-toggle"
        class="theme-toggle"
        type="button"
        aria-label="Switch to dark mode"
      >
        <svg class="icon icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <circle cx="12" cy="12" r="4.5"></circle>
          <path d="M12 2.5v3M12 18.5v3M21.5 12h-3M5.5 12h-3M18.36 5.64l-2.12 2.12M7.76 16.24l-2.12 2.12M18.36 18.36l-2.12-2.12M7.76 7.76 5.64 5.64"></path>
        </svg>
        <svg class="icon icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <path d="M20.2 14.6A8.5 8.5 0 1 1 9.4 3.8a6.8 6.8 0 0 0 10.8 10.8z"></path>
        </svg>
      </button>

      <nav class="nav-desktop" aria-label="Main navigation">
        <ul class="nav-list">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={currentPath === item.href ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
          <li>
            <a class="button button--sage nav-cta" href="/#download">Get the App</a>
          </li>
        </ul>
      </nav>

      <button
        id="menu-toggle"
        class="menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Open menu"
      >
        <span class="menu-toggle__icon" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile navigation" hidden>
    <ul>
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={currentPath === item.href ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <a class="button button--sage" href="/#download">Get the App</a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    background: var(--surface-card);
    border-bottom: 1px solid var(--border-subtle);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.65rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    min-width: 0;
  }

  .brand img {
    border-radius: 10px;
    flex-shrink: 0;
  }

  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .brand__text strong {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--heading);
  }

  .brand__text small {
    color: var(--ink-muted);
    font-size: 0.8rem;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  /* Theme toggle */
  .theme-toggle {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    background: transparent;
    color: var(--heading);
    cursor: pointer;
    flex-shrink: 0;
    transition: background-color 120ms ease, transform 120ms ease;
  }

  .theme-toggle:hover {
    background: var(--border-subtle);
  }

  .theme-toggle .icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  /* Desktop nav */
  .nav-desktop .nav-list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem 1.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-desktop .nav-list a:not(.nav-cta) {
    font-family: var(--font-display);
    font-weight: 600;
    text-decoration: none;
    color: var(--heading);
    padding-block: 0.4rem;
  }

  .nav-desktop .nav-list a[aria-current='page'] {
    border-bottom: 3px solid var(--sage);
  }

  .nav-cta {
    padding: 0.5rem 1.2rem;
    font-size: 0.95rem;
  }

  /* Hamburger — hidden on desktop */
  .menu-toggle {
    display: none;
    width: 2.4rem;
    height: 2.4rem;
    padding: 0;
    border: 1px solid var(--border-subtle);
    border-radius: 0.6rem;
    background: transparent;
    cursor: pointer;
    flex-shrink: 0;
  }

  .menu-toggle__icon {
    position: relative;
    display: block;
    width: 1.2rem;
    height: 0.9rem;
    margin: 0 auto;
  }

  .menu-toggle__icon span {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    border-radius: 2px;
    background: var(--heading);
    transition: transform 150ms ease, opacity 150ms ease, top 150ms ease;
  }

  .menu-toggle__icon span:nth-child(1) {
    top: 0;
  }

  .menu-toggle__icon span:nth-child(2) {
    top: 50%;
    transform: translateY(-50%);
  }

  .menu-toggle__icon span:nth-child(3) {
    top: 100%;
    transform: translateY(-100%);
  }

  .menu-toggle[aria-expanded='true'] .menu-toggle__icon span:nth-child(1) {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
  }

  .menu-toggle[aria-expanded='true'] .menu-toggle__icon span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle[aria-expanded='true'] .menu-toggle__icon span:nth-child(3) {
    top: 50%;
    transform: translateY(-50%) rotate(-45deg);
  }

  /* Mobile nav panel — hidden on desktop entirely */
  .mobile-nav {
    display: none;
  }

  @media (max-width: 860px) {
    .nav-desktop {
      display: none;
    }

    .menu-toggle {
      display: block;
    }

    .site-header {
      position: static;
    }

    .mobile-nav[hidden] {
      display: none;
    }

    .mobile-nav {
      display: block;
      border-top: 1px solid var(--border-subtle);
      background: var(--surface-card);
    }

    .mobile-nav ul {
      list-style: none;
      margin: 0;
      padding: 0.75rem clamp(1.1rem, 4vw, 2rem) 1.25rem;
      display: grid;
      gap: 0.75rem;
    }

    .mobile-nav a:not(.button) {
      display: block;
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 1.05rem;
      text-decoration: none;
      color: var(--heading);
      padding-block: 0.35rem;
    }

    .mobile-nav a[aria-current='page'] {
      color: var(--sage-dark);
    }

    .mobile-nav .button {
      display: inline-block;
      margin-top: 0.25rem;
    }
  }
</style>

<script>
  const root = document.documentElement;
  const themeToggle = document.getElementById('theme-toggle');
  const STORAGE_KEY = 'theme';

  function currentTheme(): 'light' | 'dark' {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored === 'light' || stored === 'dark') return stored;
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function applyTheme(theme: 'light' | 'dark', persist: boolean) {
    root.setAttribute('data-theme', theme);
    if (persist) localStorage.setItem(STORAGE_KEY, theme);
    themeToggle?.setAttribute(
      'aria-label',
      theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'
    );
  }

  applyTheme(currentTheme(), false);

  themeToggle?.addEventListener('click', () => {
    applyTheme(currentTheme() === 'dark' ? 'light' : 'dark', true);
  });

  // Mobile menu
  const menuToggle = document.getElementById('menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  function closeMenu() {
    if (!menuToggle || !mobileNav) return;
    menuToggle.setAttribute('aria-expanded', 'false');
    menuToggle.setAttribute('aria-label', 'Open menu');
    mobileNav.hidden = true;
  }

  function openMenu() {
    if (!menuToggle || !mobileNav) return;
    menuToggle.setAttribute('aria-expanded', 'true');
    menuToggle.setAttribute('aria-label', 'Close menu');
    mobileNav.hidden = false;
  }

  menuToggle?.addEventListener('click', () => {
    if (menuToggle.getAttribute('aria-expanded') === 'true') closeMenu();
    else openMenu();
  });

  mobileNav?.addEventListener('click', (event) => {
    if ((event.target as HTMLElement).closest('a')) closeMenu();
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMenu();
  });

  const desktopBreakpoint = window.matchMedia('(min-width: 861px)');
  desktopBreakpoint.addEventListener('change', (event) => {
    if (event.matches) closeMenu();
  });
</script>
